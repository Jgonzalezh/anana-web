---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/equipos', label: 'Equipos' },
  { href: '/programacion', label: 'Programación' },
  { href: '/resultados', label: 'Resultados' },
  { href: '/posiciones', label: 'Posiciones' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-negro/95 backdrop-blur-sm border-b border-dorado/20">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <span class="font-display text-2xl text-dorado tracking-widest group-hover:text-dorado-claro transition-colors">AÑAÑA</span>
      <span class="hidden sm:block h-5 w-px bg-white/20"></span>
      <span class="hidden sm:block text-white/40 text-xs tracking-widest uppercase">Torneo Beneficencia</span>
    </a>

    <ul class="hidden md:flex items-center gap-1">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={`px-4 py-2 text-sm font-medium rounded transition-colors ${
              currentPath === link.href
                ? 'text-dorado'
                : 'text-white/60 hover:text-white'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="ml-2">
        <a
          href="/inscripcion"
          class="px-5 py-2 bg-dorado text-negro text-sm font-bold rounded hover:bg-dorado-claro transition-colors"
        >
          Inscribirse
        </a>
      </li>
    </ul>

    <button id="menu-btn" class="md:hidden p-2 text-white/60 hover:text-white" aria-label="Abrir menú">
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-negro/98">
    <ul class="py-3 px-4 space-y-1">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={`block px-3 py-2.5 text-sm font-medium rounded transition-colors ${
              currentPath === link.href ? 'text-dorado' : 'text-white/60 hover:text-white'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/inscripcion" class="block px-3 py-3 bg-dorado text-negro text-sm font-bold rounded text-center">
          Inscribir equipo
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
