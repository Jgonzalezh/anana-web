---
import Layout from '../layouts/Layout.astro';
import torneo from '../data/torneo.json';
---

<Layout title="Programación" description="Programación de partidos del Torneo Beneficencia de Añaña Club Deportivo.">
  <div class="pt-24 pb-20 max-w-5xl mx-auto px-4">

    <div class="mb-12">
      <p class="section-label">Torneo Beneficencia 2026</p>
      <h1 class="section-title">PROGRAMACIÓN</h1>
      <p class="text-white/40 text-sm mt-3">{torneo.fecha} · {torneo.lugar}</p>
    </div>

    <div id="lista-partidos">
      <p class="text-white/30 text-sm">Cargando programación...</p>
    </div>
  </div>
</Layout>

<script>
  import { db } from '../lib/firebase.js';
  import { collection, getDocs } from 'firebase/firestore';

  async function load() {
    try {
    const snap = await getDocs(collection(db, 'partidos'));
    const partidos = snap.docs.map(d => ({ id: d.id, ...d.data() })).sort((a, b) => a.hora.localeCompare(b.hora));
    const container = document.getElementById('lista-partidos');

    if (partidos.length === 0) {
      container.innerHTML = `
        <div class="bg-fondo-card border border-white/10 rounded-xl p-16 text-center">
          <div class="font-display text-7xl text-dorado mb-6 opacity-60">PRONTO</div>
          <p class="text-white/50 text-lg mb-2">El fixture se publicará una vez confirmados todos los equipos.</p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/equipos" class="px-8 py-4 border border-white/30 text-white font-medium rounded hover:border-dorado hover:text-dorado transition-colors">Ver equipos inscritos</a>
            <a href="/inscripcion" class="px-8 py-4 bg-dorado text-negro font-bold rounded hover:bg-dorado-claro transition-all">Inscribir equipo</a>
          </div>
        </div>`;
      return;
    }

    container.innerHTML = '<div class="space-y-2">' + partidos.map(p => `
      <div class="rounded-xl border p-4 flex items-center gap-4 transition-colors ${
        p.estado === 'finalizado' ? 'bg-fondo-card border-white/8'
        : p.estado === 'en_curso' ? 'bg-dorado/5 border-dorado/30'
        : 'bg-fondo-card border-white/10'
      }">
        <div class="text-white/35 text-xs font-medium w-14 shrink-0">${p.hora}</div>
        <div class="flex-1 grid grid-cols-[1fr_auto_1fr] items-center gap-3 min-w-0">
          <p class="font-semibold text-white text-sm text-right truncate">${p.local}</p>
          <div class="text-center shrink-0">
            ${p.estado === 'finalizado'
              ? `<span class="font-display text-2xl text-dorado leading-none tracking-wider">${p.marcador_local} - ${p.marcador_visitante}</span>`
              : p.estado === 'en_curso'
              ? `<span class="font-display text-xl text-dorado/70 leading-none">${p.marcador_local || 0} - ${p.marcador_visitante || 0}</span>`
              : '<span class="text-white/30 text-xs font-medium tracking-widest">VS</span>'}
          </div>
          <p class="font-semibold text-white text-sm text-left truncate">${p.visitante}</p>
        </div>
        ${p.estado === 'en_curso' ? '<span class="flex items-center gap-1 text-dorado text-xs shrink-0"><span class="w-1.5 h-1.5 bg-dorado rounded-full animate-pulse"></span>Jugando</span>' : ''}
      </div>
    `).join('') + '</div>';
    } catch (err) {
      document.getElementById('lista-partidos').innerHTML = `<p class="text-red-400 text-sm">Error: ${err.message}</p>`;
      console.error('Firestore error:', err);
    }
  }

  load();
</script>
