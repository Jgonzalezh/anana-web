---
import Layout from '../layouts/Layout.astro';
import torneo from '../data/torneo.json';
import partidosData from '../data/partidos.json';

const finalizados = partidosData.partidos.filter(p => p.estado === 'finalizado');
const hayResultados = finalizados.length > 0;

const porJornada = torneo.jornadas.map(j => ({
  ...j,
  partidos: finalizados.filter(p => p.jornada === j.numero),
})).filter(j => j.partidos.length > 0);
---

<Layout title="Resultados" description="Resultados de los partidos del Torneo Beneficencia de Añaña Basketball.">
  <div class="pt-24 pb-20 max-w-5xl mx-auto px-4">

    <div class="mb-12">
      <p class="section-label">Torneo Beneficencia 2026</p>
      <h1 class="section-title">RESULTADOS</h1>
    </div>

    {!hayResultados ? (
      <div class="card p-16 text-center">
        <div class="font-display text-7xl text-dorado mb-6 opacity-60">PRONTO</div>
        <p class="text-white/50 text-lg mb-2">Los resultados se publicarán a medida que se jueguen los partidos.</p>
        <p class="text-white/30 text-sm">Revisa la programación para ver los próximos partidos.</p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/programacion" class="btn-outline">Ver programación</a>
          <a href="/posiciones" class="btn-primary">Ver posiciones</a>
        </div>
      </div>
    ) : (
      <div class="space-y-12">
        {porJornada.map(jornada => (
          <div>
            <div class="flex items-center gap-4 mb-6 flex-wrap">
              <h2 class="font-display text-3xl text-white tracking-wide">
                JORNADA {jornada.numero}
              </h2>
              <span class="text-white/35 text-sm">{jornada.fecha}</span>
              <span class="text-white/25 text-xs">{jornada.partidos.length} partidos jugados</span>
            </div>

            <div class="space-y-2">
              {jornada.partidos.map(partido => (
                <div class="rounded-xl border bg-fondo-card border-white/8 p-4 flex items-center gap-4">
                  <div class="text-white/35 text-xs font-medium w-14 shrink-0">{partido.hora}</div>

                  <div class="flex-1 grid grid-cols-[1fr_auto_1fr] items-center gap-3 min-w-0">
                    <p class="font-semibold text-white text-sm text-right truncate">{partido.local}</p>
                    <div class="text-center shrink-0">
                      <span class="font-display text-2xl text-dorado leading-none tracking-wider">
                        {partido.marcador_local} - {partido.marcador_visitante}
                      </span>
                    </div>
                    <p class="font-semibold text-white text-sm text-left truncate">{partido.visitante}</p>
                  </div>

                  {partido.fase && (
                    <div class="text-white/25 text-xs shrink-0 hidden sm:block">{partido.fase}</div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}

        <div class="text-center pt-4">
          <a href="/posiciones" class="btn-outline">Ver tabla de posiciones</a>
        </div>
      </div>
    )}
  </div>
</Layout>
