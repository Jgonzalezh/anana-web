---
import Layout from '../layouts/Layout.astro';
import torneo from '../data/torneo.json';
---

<Layout title="Equipos" description="Equipos inscritos en el Torneo Beneficencia de Añaña Club Deportivo.">
  <div class="pt-24 pb-20 max-w-6xl mx-auto px-4">

    <div class="mb-12">
      <p class="section-label">Torneo Beneficencia 2026</p>
      <h1 class="font-display text-5xl md:text-6xl text-white tracking-wide">
        EQUIPOS <span class="text-dorado">INSCRITOS</span>
      </h1>
      <div class="mt-5 flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-1 max-w-xs">
          <div class="h-2 bg-white/10 rounded-full overflow-hidden">
            <div id="barra-progreso" class="h-full bg-dorado rounded-full transition-all" style="width: 0%"></div>
          </div>
          <p id="texto-progreso" class="text-white/40 text-xs mt-2">Cargando...</p>
        </div>
        <a href="/inscripcion" id="link-cupos" class="hidden items-center gap-2 text-dorado hover:text-dorado-claro text-sm font-medium transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          <span id="texto-cupos"></span>
        </a>
      </div>
    </div>

    <div id="grid-equipos" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      <p class="text-white/30 text-sm col-span-full">Cargando equipos...</p>
    </div>

    <div id="banner-cupos" class="mt-12 bg-gradient-to-r from-marino/30 to-negro border border-dorado/15 rounded-2xl p-8 flex-col sm:flex-row items-center justify-between gap-6 hidden">
      <div>
        <p class="font-display text-3xl text-white tracking-wide">
          QUEDAN <span class="text-dorado" id="banner-num"></span> CUPOS
        </p>
        <p class="text-white/40 text-sm mt-1">No te quedes afuera del torneo.</p>
      </div>
      <a href="/inscripcion" class="btn-primary shrink-0">INSCRIBIR EQUIPO</a>
    </div>
  </div>
</Layout>

<script>
  import { db } from '../lib/firebase.js';
  import { collection, getDocs } from 'firebase/firestore';

  const CUPOS = 14;

  async function load() {
    try {
    const snap = await getDocs(collection(db, 'equipos'));
    const equipos = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    const confirmados = equipos.filter(e => e.confirmado).sort((a, b) => a.nombre.localeCompare(b.nombre));
    const cuposLibres = CUPOS - confirmados.length;
    const porcentaje = Math.round((confirmados.length / CUPOS) * 100);

    document.getElementById('barra-progreso').style.width = `${porcentaje}%`;
    document.getElementById('texto-progreso').textContent = `${confirmados.length} de ${CUPOS} equipos confirmados`;

    if (cuposLibres > 0) {
      const link = document.getElementById('link-cupos');
      link.classList.remove('hidden');
      link.classList.add('inline-flex');
      document.getElementById('texto-cupos').textContent = `${cuposLibres} cupos disponibles`;
    }

    const grid = document.getElementById('grid-equipos');
    let html = confirmados.map(eq => `
      <div class="bg-fondo-card border border-dorado/20 rounded-xl hover:border-dorado/30 transition-colors p-6 flex flex-col items-center text-center">
        <div class="w-16 h-16 bg-gradient-to-br from-marino to-marino-claro rounded-xl flex items-center justify-center mb-4 shadow-lg">
          <span class="font-display text-dorado text-2xl leading-none">${eq.nombre.charAt(0).toUpperCase()}</span>
        </div>
        <p class="font-semibold text-white text-sm leading-tight mb-1">${eq.nombre}</p>
        <div class="mt-3">
          ${eq.es_organizador
            ? '<span class="text-xs text-dorado/60 border border-dorado/20 rounded-full px-2.5 py-0.5">Organizador</span>'
            : '<span class="flex items-center gap-1 text-xs text-emerald-400/70"><span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>Confirmado</span>'}
        </div>
      </div>
    `).join('');

    for (let i = 0; i < cuposLibres; i++) {
      html += `
        <a href="/inscripcion" class="border border-dashed border-white/10 rounded-xl p-6 flex flex-col items-center text-center hover:border-dorado/25 transition-colors group">
          <div class="w-16 h-16 bg-white/4 rounded-xl flex items-center justify-center mb-4 group-hover:bg-dorado/8 transition-colors">
            <svg class="w-6 h-6 text-white/15 group-hover:text-dorado/35 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" />
            </svg>
          </div>
          <p class="text-white/20 text-sm group-hover:text-white/40 transition-colors">Cupo disponible</p>
        </a>`;
    }
    grid.innerHTML = html;

    if (cuposLibres > 0) {
      const banner = document.getElementById('banner-cupos');
      banner.classList.remove('hidden');
      banner.classList.add('flex');
      document.getElementById('banner-num').textContent = cuposLibres;
    }
    } catch (err) {
      document.getElementById('grid-equipos').innerHTML = `<p class="text-red-400 text-sm col-span-full">Error cargando equipos: ${err.message}</p>`;
      console.error('Firestore error:', err);
    }
  }

  load();
</script>
